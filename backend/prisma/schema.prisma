// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(uuid())
  phone             String             @unique
  password          String
  role              String
  residents         Resident[]
  passwordResetOtps PasswordResetOtp[]
}

model PasswordResetOtp {
  id        String   @id @default(uuid())
  userId    String
  phone     String
  email     String
  otpHash   String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Society {
  id             String          @id @default(uuid())
  country        String
  state          String
  city           String
  area           String
  pincode        String
  name           String
  type           String
  createdAt      DateTime        @default(now())
  residents      Resident[]
  apartmentUnits ApartmentUnit[]
  maintenancePayments MaintenancePayment[]

  @@unique([country, state, city, area, name])
}

model ApartmentUnit {
  id         String   @id @default(uuid())
  societyId  String
  flatNumber String
  createdAt  DateTime @default(now())
  society    Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  maintenancePayments MaintenancePayment[]

  @@unique([societyId, flatNumber])
}

model Resident {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  phone         String   @unique
  flatNo        String
  isActive      Boolean  @default(true)
  movedOutAt    DateTime?
  userId        String
  societyId     String?
  user          User     @relation(fields: [userId], references: [id])
  society       Society? @relation(fields: [societyId], references: [id])
  visitors                     Visitor[]
  requests                     MaintenanceRequest[]
  bookings                     Booking[]
  notifications                Notification[]
  maintenancePayments          MaintenancePayment[] @relation("MaintenanceCollector")
  teleconsultationAppointments TeleconsultationAppointment[]
}

model MaintenancePayment {
  id                   String   @id @default(uuid())
  societyId            String
  apartmentUnitId      String
  flatNumber           String
  cycleMonth           String
  amount               Int
  collectedAt          DateTime?
  collectedByResidentId String?
  createdAt            DateTime @default(now())
  society              Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  apartmentUnit        ApartmentUnit @relation(fields: [apartmentUnitId], references: [id], onDelete: Cascade)
  collectedByResident  Resident? @relation("MaintenanceCollector", fields: [collectedByResidentId], references: [id])

  @@unique([societyId, apartmentUnitId, cycleMonth])
}

model Announcement {
  id           String   @id @default(uuid())
  title        String
  content      String
  targetRoles  String[]
  createdByRole String  @default("chairman")
  createdByName String?
  createdAt    DateTime @default(now())
}

model MaintenanceRequest {
  id          String   @id @default(uuid())
  description String
  residentId  String
  resident    Resident @relation(fields: [residentId], references: [id])
}

model Visitor {
  id          String   @id @default(uuid())
  name        String
  purpose     String
  residentId  String
  resident    Resident @relation(fields: [residentId], references: [id])
}

model Facility {
  id               String   @id @default(uuid())
  name             String   @unique
  capacity         Int      @default(1)
  requiresTimeslot Boolean  @default(false)
  bookings         Booking[]
}

model Booking {
  id                   String   @id @default(uuid())
  facilityId           String
  residentId           String
  date                 DateTime
  bookingDate          String
  timeSlot             String?
  status               String   @default("pending")
  approvedAt           DateTime?
  approvedByResidentId String?
  rejectedAt           DateTime?
  facility             Facility @relation(fields: [facilityId], references: [id])
  resident             Resident @relation(fields: [residentId], references: [id])

  @@index([facilityId, bookingDate, timeSlot, status])
}

model Notification {
  id          String   @id @default(uuid())
  message     String
  createdAt   DateTime @default(now())
  residentId  String
  resident    Resident @relation(fields: [residentId], references: [id])
}

model Doctor {
  id               String   @id @default(uuid())
  name             String   @unique
  specialty        String
  bio              String   @default("")
  availableDays    String   @default("Mon,Tue,Wed,Thu,Fri")
  availableSlots   String   @default("09:00-09:30,09:30-10:00,10:00-10:30,10:30-11:00,14:00-14:30,14:30-15:00,15:00-15:30,15:30-16:00")
  createdAt        DateTime @default(now())
  appointments     TeleconsultationAppointment[]
}

model TeleconsultationAppointment {
  id          String   @id @default(uuid())
  doctorId    String
  residentId  String
  date        String
  timeSlot    String
  status      String   @default("scheduled")
  createdAt   DateTime @default(now())
  doctor      Doctor   @relation(fields: [doctorId], references: [id])
  resident    Resident @relation(fields: [residentId], references: [id])
  messages    TeleconsultationMessage[]

  @@index([residentId, date])
  @@index([doctorId, date])
}

model TeleconsultationMessage {
  id            String   @id @default(uuid())
  appointmentId String
  senderId      String
  senderName    String
  message       String
  sentAt        DateTime @default(now())
  appointment   TeleconsultationAppointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId, sentAt])
}
